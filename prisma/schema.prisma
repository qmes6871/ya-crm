// YA Solution CRM Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== 사용자 관련 ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  permissions   UserPermission?
  incentives    UserIncentive?

  // 담당자로 배정된 프로젝트
  projects      Project[]

  // 상담자로 배정된 가망고객
  leads         Lead[]

  // 개인 업무
  tasks         Task[]
  assignedTasks Task[]    @relation("AssignedTasks")

  // 캘린더 일정
  calendarEvents CalendarEvent[]

  // 커뮤니케이션 코멘트
  comments      ProjectComment[]

  // 문서 관리
  quotes        Quote[]
  uploadedFiles File[]

  // 정산
  settlements   Settlement[]
  cashAdvances  CashAdvance[]

  // 계정 관리
  managedAccounts ManagedAccount[]

  // 알림 설정
  notificationSettings NotificationSetting?
  notifications        Notification[]

  // 출퇴근
  attendances   Attendance[]

  // OB영업
  obLeads       ObLead[]      @relation("ObLeadAssignee")
  obLeadsCreated ObLead[]     @relation("ObLeadCreator")
  obCallLogs    ObCallLog[]

  @@map("users")
}

enum UserRole {
  ADMIN
  DEVELOPER
  SALES
  USER
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 메뉴별 접근 권한
  dashboard     Boolean @default(true)
  attendance    Boolean @default(true)
  clients       Boolean @default(true)
  projects      Boolean @default(true)
  leads         Boolean @default(true)
  tasks         Boolean @default(true)
  documents     Boolean @default(true)
  accounts      Boolean @default(true)
  servers       Boolean @default(true)
  settlements   Boolean @default(true)
  revenue       Boolean @default(true)
  obSales       Boolean @default(true)
  settings      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_permissions")
}

model UserIncentive {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 인센티브 비율 (%)
  revenueRate     Float    @default(0)   // 매출 비율
  advanceRate     Float    @default(0)   // 선수금 (미사용)
  midPaymentRate  Float    @default(0)   // 중도금 (미사용)
  balanceRate     Float    @default(0)   // 잔금 (미사용)
  fullPaymentRate Float    @default(0)   // 전체지급 비율

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_incentives")
}

// ==================== 출퇴근 관련 ====================

model Attendance {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date                    // 출근 날짜
  checkIn   DateTime?                             // 출근 시간
  checkOut  DateTime?                             // 퇴근 시간

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendances")
}

// ==================== 거래처 관련 ====================

model Client {
  id              String   @id @default(cuid())
  name            String                          // 거래처명
  contact         String?                         // 연락처
  contractDate    DateTime?                       // 계약날짜
  firstDraftDate  DateTime?                       // 1차 시안 공유 일정
  requirements    String?  @db.Text               // 진행 요청사항
  note            String?  @db.Text               // 비고

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  requestTypes    ClientRequestType[]
  payments        ClientPayment[]
  projects        Project[]

  @@map("clients")
}

model ClientRequestType {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      RequestType
  customType String?                             // 비고 (직접 입력)

  @@map("client_request_types")
}

enum RequestType {
  WEB_DEV          // 웹 개발
  SHOPPING_MALL    // 쇼핑몰 개발
  APP_DEV          // 앱 개발
  PLATFORM_DEV     // 플랫폼 개발
  CRM_DEV          // CRM 개발
  OTHER            // 비고
}

model ClientPayment {
  id        String      @id @default(cuid())
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      PaymentType
  amount    Float                                // 금액

  @@map("client_payments")
}

enum PaymentType {
  ADVANCE      // 선수금
  MID_PAYMENT  // 중도금
  BALANCE      // 잔금
  FULL_PAYMENT // 전체지급
}

// ==================== 프로젝트 관련 ====================

model Project {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  managerId   String
  manager     User          @relation(fields: [managerId], references: [id])
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)
  progress    Int           @default(0)          // 진행률 (0-100)
  deadline    DateTime?                          // 최종 마감일
  firstDraftDate         DateTime?               // 1차 시안 공유 예정일
  firstDraftCompletedAt  DateTime?               // 1차 시안 공유 완료 시각
  secondDraftDate        DateTime?               // 2차 시안 공유 예정일
  secondDraftCompletedAt DateTime?               // 2차 시안 공유 완료 시각
  serverCost       String?                       // 서버비용 타입
  serverCostCustom String?                       // 서버비용 기타 텍스트
  maintenance      String?                       // 유지보수 타입
  maintenanceCustom String?                      // 유지보수 기타 텍스트

  // 작업지시서
  instructionPurpose  String? @db.Text           // 목적/배경
  instructionFeatures String? @db.Text           // 주요 기능
  instructionDesign   String? @db.Text           // 디자인 참고
  instructionPages    String? @db.Text           // 페이지 구성
  instructionNotes    String? @db.Text           // 특이사항

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  schedules   ProjectSchedule[]
  tasks       Task[]
  comments    ProjectComment[]
  files       File[]
  contracts   ProjectContract[]
  revenues    Revenue[]
  payments    ProjectPayment[]
  servers     Server[]

  @@map("projects")
}

model ProjectPayment {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      PaymentType
  amount    Float                                // 금액

  @@map("project_payments")
}

enum ProjectStatus {
  PLANNING           // 기획
  FIRST_DRAFT        // 1차 시안 작업
  FIRST_DRAFT_REVIEW // 1차 시안 공개
  REVISION           // 시안 수정
  FINAL_REVIEW       // 시안 공개
  OPEN               // 오픈
  COMPLETED          // 완료
}

model ProjectSchedule {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage       ProjectStatus  @default(PLANNING)
  stageName   String                             // 단계명 (필수)
  startDate   DateTime?
  endDate     DateTime?
  status      ScheduleStatus @default(PENDING)   // 작업 상태
  sortOrder   Int            @default(0)

  @@map("project_schedules")
}

enum ScheduleStatus {
  PENDING      // 대기
  IN_PROGRESS  // 작업중
  COMPLETED    // 완료
}

model ProjectComment {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String   @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 첨부 파일
  attachments CommentAttachment[]

  @@map("project_comments")
}

model CommentAttachment {
  id        String         @id @default(cuid())
  commentId String
  comment   ProjectComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  fileName  String
  filePath  String
  fileSize  Int
  mimeType  String?

  @@map("comment_attachments")
}

model ProjectContract {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  fileName    String
  filePath    String
  fileSize    Int
  mimeType    String?

  createdAt   DateTime @default(now())

  @@map("project_contracts")
}

// ==================== 가망고객 관련 ====================

model Lead {
  id               String       @id @default(cuid())
  consultantId     String
  consultant       User         @relation(fields: [consultantId], references: [id])
  consultDate      DateTime     @default(now())      // 상담날짜
  customerName     String                            // 고객 성함 및 회사명
  contact          String?                           // 연락처
  inquiry          String?      @db.Text             // 고객 문의사항
  result           LeadResult   @default(NOT_CALCULATED)
  resultNote       String?                           // 결과 비고

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  sources          LeadSource[]
  quotes           LeadQuote[]

  @@map("leads")
}

enum LeadResult {
  NOT_CALCULATED   // 결과 미 산출
  QUOTE_PROVIDED   // 견적 안내
  QUOTE_SENT       // 견적서 납기
  MEETING          // 미팅
  WAITING_RESPONSE // 회신 기다리는중
  OTHER            // 비고
}

model LeadSource {
  id         String     @id @default(cuid())
  leadId     String
  lead       Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type       SourceType
  customType String?                              // 기타 (직접 입력)

  @@map("lead_sources")
}

enum SourceType {
  SOOMGO      // 숨고
  KMONG       // 크몽
  PHONE       // 전화
  WEBSITE     // 홈페이지 접수
  OTHER       // 기타
}

model LeadQuote {
  id        String      @id @default(cuid())
  leadId    String
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      PaymentType
  amount    Float                                // 금액

  @@map("lead_quotes")
}

// ==================== 업무/일정 관련 ====================

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(NORMAL)
  deadline    DateTime?

  // 생성자
  creatorId   String
  creator     User         @relation(fields: [creatorId], references: [id])

  // 담당자 (본인 또는 다른 사용자)
  assigneeId  String
  assignee    User         @relation("AssignedTasks", fields: [assigneeId], references: [id])

  // 프로젝트 연동 (선택)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  TODO        // 할 일
  IN_PROGRESS // 진행
  REVIEW      // 검토
  COMPLETED   // 완료
}

enum TaskPriority {
  LOW         // 낮음
  NORMAL      // 보통
  HIGH        // 높음
  URGENT      // 긴급
}

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)

  // 업무와 연동 (선택)
  taskId      String?  @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("calendar_events")
}

// ==================== 문서관리 관련 ====================

model Quote {
  id           String      @id @default(cuid())
  creatorId    String
  creator      User        @relation(fields: [creatorId], references: [id])
  quoteNumber  String      @unique               // 견적서 번호
  clientName   String                            // 고객/회사명
  clientContact String?                          // 연락처
  validUntil   DateTime?                         // 유효기간
  totalAmount  Float       @default(0)           // 총 금액
  note         String?     @db.Text              // 비고
  notices      String?     @db.Text              // 안내사항 (커스텀)
  status       QuoteStatus @default(DRAFT)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  items        QuoteItem[]

  @@map("quotes")
}

enum QuoteStatus {
  DRAFT      // 초안
  SENT       // 발송됨
  ACCEPTED   // 승인됨
  REJECTED   // 거절됨
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String                             // 항목 설명
  quantity    Int    @default(1)                 // 수량
  unitPrice   Float                              // 단가
  amount      Float                              // 금액

  @@map("quote_items")
}

model File {
  id          String    @id @default(cuid())
  uploaderId  String
  uploader    User      @relation(fields: [uploaderId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  fileName    String
  originalName String
  filePath    String
  fileSize    Int
  mimeType    String?
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("files")
}

// ==================== 정산/매출 관련 ====================

model Settlement {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  category    String      @default("BONUS")      // BONUS, ALLOWANCE, DEDUCTION, OTHER
  amount      Float                              // 정산 금액
  description String?
  targetDate  DateTime?                          // 정산 대상 날짜
  isPaid      Boolean     @default(false)
  paidAt      DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("settlements")
}

model CashAdvance {
  id                String            @id @default(cuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  amount            Float
  reason            String?
  status            CashAdvanceStatus @default(PENDING)
  periodStart       DateTime
  periodEnd         DateTime
  settlementSnapshot Float            // 신청 시점 정산금 스냅샷
  approvedBy        String?
  approvedAt        DateTime?
  paidAt            DateTime?
  rejectedReason    String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("cash_advances")
}

enum CashAdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Revenue {
  id          String      @id @default(cuid())
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type        PaymentType
  amount      Float
  description String?
  receivedAt  DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("revenues")
}

model Expense {
  id          String   @id @default(cuid())
  category    String                             // 카테고리
  amount      Float
  description String?
  paidAt      DateTime?

  attachments ExpenseAttachment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model ExpenseAttachment {
  id           String  @id @default(cuid())
  expenseId    String
  expense      Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  filePath     String
  fileSize     Int
  mimeType     String?

  createdAt    DateTime @default(now())

  @@map("expense_attachments")
}

// ==================== 계정관리 관련 ====================

model ManagedAccount {
  id           String      @id @default(cuid())
  ownerId      String
  owner        User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  platform     String                            // 플랫폼
  accountId    String                            // 아이디
  password     String                            // 비밀번호 (암호화 필요)
  socialLogin  SocialLoginType?
  socialNote   String?                           // 소셜로그인 비고
  isShared     Boolean     @default(false)       // 공유 계정 여부

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("managed_accounts")
}

enum SocialLoginType {
  NAVER
  KAKAO
  GOOGLE
  OTHER
}

// ==================== 서버 관리 관련 ====================

model Server {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name            String                          // 서버명
  serverType      String?                         // 서버 타입 (GENERAL, BUSINESS, etc.)
  serverTypeCustom String?                        // 기타 타입 텍스트
  localPath       String?                         // 로컬 폴더 경로 (/var/www 하위)
  paymentDay      Int?                            // 서버 비용 결제일 (1-31)
  isActive        Boolean  @default(true)         // 서버 활성화 상태
  suspendedAt     DateTime?                       // 중단 일시

  hostingProvider       String?                   // 호스팅 업체 (SELF, CAFE24, GABIA, AWS, OTHER)
  hostingProviderCustom String?                   // 기타 호스팅 업체명
  ipAddress             String?                   // IP 주소 (레거시)
  domain          String?                         // 도메인
  githubUrl       String?                         // 깃허브 경로

  adminUrl        String?                         // 관리자 URL
  adminId         String?                         // 관리자 아이디
  adminPassword   String?                         // 관리자 비밀번호

  ftpHost         String?                         // FTP 호스트
  ftpId           String?                         // FTP 아이디
  ftpPassword     String?                         // FTP 비밀번호
  ftpPort         String?                         // FTP 포트

  dbHost          String?                         // DB 호스트
  dbPort          String?                         // DB 포트
  dbName          String?                         // DB 이름
  dbUser          String?                         // DB 사용자
  dbPassword      String?                         // DB 비밀번호

  note            String?  @db.Text               // 메모
  trafficResetAt  DateTime?                       // 트래픽 초기화 날짜

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("servers")
}

// ==================== 알림 관련 ====================

model NotificationSetting {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 알림 채널 설정
  emailEnabled  Boolean @default(true)
  smsEnabled    Boolean @default(false)
  kakaoEnabled  Boolean @default(false)

  // 알림 유형별 설정
  taskReminder  Boolean @default(true)
  projectUpdate Boolean @default(true)
  newLead       Boolean @default(true)
  settlement    Boolean @default(true)

  @@map("notification_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String   @db.Text
  link      String?
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
}

// ==================== OB영업 관련 ====================

model ObLead {
  id          String       @id @default(cuid())
  phone       String                              // 전화번호
  customerName String?                            // 고객명
  customerLink String?                            // 고객 링크
  memo        String?      @db.Text               // 메모
  status      ObLeadStatus @default(NEW)          // 현재 상태
  assignedDate DateTime?                          // 배정일
  assigneeId  String?                             // 담당자
  assignee    User?        @relation("ObLeadAssignee", fields: [assigneeId], references: [id])
  creatorId   String                              // 등록자 (관리자)
  creator     User         @relation("ObLeadCreator", fields: [creatorId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  callLogs    ObCallLog[]

  @@map("ob_leads")
}

enum ObLeadStatus {
  NEW        // 신규
  REJECTED   // 거절
  NO_ANSWER  // 부재
  CALLBACK   // 재통
  PROSPECT   // 가망
  DESIGN     // 시안제작
  CONTRACT   // 계약
}

model ObCallLog {
  id        String       @id @default(cuid())
  leadId    String
  lead      ObLead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  callerId  String                                // 통화한 담당자
  caller    User         @relation(fields: [callerId], references: [id])
  result    ObLeadStatus                          // 통화 결과
  note      String?      @db.Text                 // 통화 내용
  calledAt  DateTime     @default(now())          // 통화 시간

  @@map("ob_call_logs")
}
